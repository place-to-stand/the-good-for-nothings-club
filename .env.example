VERCEL_ENV=development
NEXT_PUBLIC_VERCEL_ENV=development

# https://developers.google.com/maps/documentation/javascript/get-api-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key

RESEND_API_KEY=your_api_key

# PostHog project API key (public, write-only) — Settings > Project in
# https://us.posthog.com/project/525643. Init is skipped when unset or in
# local dev (see instrumentation-client.ts).
NEXT_PUBLIC_POSTHOG_KEY=

# Convex (CMS content, inquiries, and /admin auth - see convex/schema.ts)
# Written to .env.local by `npx convex dev`; set the prod deployment's
# URL on Vercel. Required for the site's project/member pages and /admin.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
